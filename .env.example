# Docker stack
POSTGRES_DB=gpn_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres12345
POSTGRES_PORT=5433

# MinIO credentials — used by docker-compose.yml
MINIO_ACCESS_KEY=gpnminio
MINIO_SECRET_KEY=gpnminiosecret123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_PREFIX=gpn

# Backend security
JWT_SECRET=replace-this-with-a-very-long-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=replace-this-with-a-very-long-refresh-secret-min-32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS/public URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# SMTP (optional for local testing)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=GBN Polytechnic <noreply@gpnilokheri.ac.in>
ADMIN_EMAIL=admin@gpnilokheri.ac.in
