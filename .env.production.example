# /opt/app/.env — Backend runtime config on the server
# Copy this file to the server: scp .env.production.example root@SERVER:/opt/app/.env
# Then fill in the real values.

# ── Hosts (used by Traefik labels in docker-compose) ──
FRONTEND_HOST=gpn.repoassistant.com
ADMIN_HOST=gpn-admin.repoassistant.com
BACKEND_HOST=gpn-api.repoassistant.com

# ── Database (must match /opt/infra/.env credentials) ──
DATABASE_URL=postgresql://gpn:COPY_POSTGRES_PASSWORD_FROM_INFRA@postgres:5432/gpn

# ── Postgres (needed by postgres-wait container) ──
POSTGRES_USER=gpn

# ── JWT — generate with: openssl rand -base64 48 ──
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── MinIO (must match /opt/infra/.env credentials) ──
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=COPY_MINIO_ROOT_USER_FROM_INFRA
MINIO_SECRET_KEY=COPY_MINIO_ROOT_PASSWORD_FROM_INFRA
MINIO_USE_SSL=false
MINIO_BUCKET_PREFIX=gpn
STORAGE_PUBLIC_URL=

# ── CORS ──
FRONTEND_URL=
ADMIN_URL=

# ── SMTP ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL=

